#!/bin/bash
# Repo-path / scratch guard (engineering-core:ground-truth-anchor, code-enforced).
# Blocks the failure-class artifacts: scratch files at repo root, accidental huge
# blobs (the 5 MB Plotly trap), nested repos, and deletion of the ground-truth docs.
set -uo pipefail
ROOT="$(git rev-parse --show-toplevel)"
staged() { git diff --cached --name-only --diff-filter=AM; }
fail=0

# 1) scratch files anywhere (the backup_old.tsx / diff.txt / test_fetch.py thrash residue)
while IFS= read -r f; do
  case "$(basename "$f")" in
    backup_old*|*_backup.*|*.bak|diff.txt|scratch.*|tmp.*|test_fetch.py|*.orig)
      echo "BLOCKED: scratch file staged: $f (engineering-core forbids scratch artifacts)"; fail=1;;
  esac
done < <(staged)

# 2) oversized files (>2MB) — catches inline mega-HTML / committed build blobs
while IFS= read -r f; do
  [ -f "$ROOT/$f" ] || continue
  sz=$(wc -c < "$ROOT/$f" 2>/dev/null || echo 0)
  if [ "$sz" -gt 2097152 ]; then echo "BLOCKED: $f is ${sz} bytes (>2MB). Don't commit large blobs."; fail=1; fi
done < <(staged)

# 3) nested git repo inside the workspace (sibling/parallel-repo trap)
while IFS= read -r d; do
  [ "$d" = "$ROOT/.git" ] && continue
  echo "BLOCKED: nested .git found at $d — no parallel/sibling repos inside the project."; fail=1
done < <(find "$ROOT" -name .git -type d -not -path "$ROOT/.git" 2>/dev/null)

# 4) ground-truth docs must not be deleted
while IFS= read -r f; do
  case "$f" in AGENTS.md|LOCKED-DECISIONS.md) echo "BLOCKED: $f is being deleted — it is the ground-truth anchor.";  fail=1;; esac
done < <(git diff --cached --name-only --diff-filter=D)

# 5) secret scan — block committing live credentials (engineering-core:secret-safety).
#    Config (e.g. .hermes/config.yaml) must reference secrets as ${VAR} (Hermes expands
#    them at load) and keep real values in a gitignored .env — never inline.
SECRET_RE='sk-[A-Za-z0-9]{20,}|xoxb-[A-Za-z0-9-]{10,}|gh[pousr]_[A-Za-z0-9]{30,}|AKIA[0-9A-Z]{16}|-----BEGIN [A-Z ]*PRIVATE KEY-----'
while IFS= read -r f; do
  case "$f" in *.env.example|*.lock) continue;; esac
  blob=$(git show ":$f" 2>/dev/null) || continue
  hits=$(printf '%s\n' "$blob" | grep -nIaE "$SECRET_RE" 2>/dev/null | grep -vE '\$\{[A-Za-z_][A-Za-z0-9_]*\}|os\.environ' || true)
  if [ -n "$hits" ]; then
    echo "BLOCKED: possible hard-coded secret in staged $f:"
    printf '%s\n' "$hits" | head -3 | sed 's/^/    /'
    echo "  -> reference secrets as \${VAR} and keep values in a gitignored .env"
    fail=1
  fi
done < <(staged)

# 6) TDD guard (engineering-core:test-driven-development, code-enforced).
#    Backend logic changes (api/services/query/agents/core) must ship with a test change.
#    Override for genuine non-feature commits: SKIP_TDD_GUARD=1 git commit ...
if [ "${SKIP_TDD_GUARD:-0}" != "1" ]; then
  logic=$(staged | grep -E '^backend/app/(api|services|query|agents|core)/.*\.py$' | grep -vE '/__init__\.py$|/schemas?/|/config\.py$' || true)
  tests=$(staged | grep -E '(^|/)tests?/|(^|/)test_.*\.py$|_test\.py$' || true)
  if [ -n "$logic" ] && [ -z "$tests" ]; then
    echo "BLOCKED (TDD): backend logic changed with NO test change:"
    printf '%s\n' "$logic" | sed 's/^/    /'
    echo "  -> write/adjust a test first (RED→GREEN). Genuinely no test needed? SKIP_TDD_GUARD=1 git commit …"
    fail=1
  fi
fi

# 7) vault schema-contract guard (see docs/vault-format-analysis.md, mirrors CI
#    job `vault-validate`). When vault markdown is staged, block duplicated/stale
#    sections before they reach the LLM prompt. Remediate: python3
#    scripts/dedup-vault-sections.py <workspace>. Override: SKIP_VAULT_GUARD=1.
if [ "${SKIP_VAULT_GUARD:-0}" != "1" ]; then
  vault=$(staged | grep -E '^docs/vaults/.+\.md$' || true)
  if [ -n "$vault" ]; then
    if ! python3 "$ROOT/scripts/validate-vault.py" >/tmp/aria-vault-validate.txt 2>&1; then
      echo "BLOCKED (vault contract): staged vault markdown violates the schema contract:"
      grep -E '✗ ERROR|^[a-z]' /tmp/aria-vault-validate.txt | sed 's/^/    /'
      echo "  -> fix: python3 scripts/dedup-vault-sections.py <workspace>  (override: SKIP_VAULT_GUARD=1)"
      fail=1
    fi
  fi
fi

[ "$fail" -eq 1 ] && { echo "--- pre-commit guard failed (engineering-core) ---"; exit 1; }
exit 0
