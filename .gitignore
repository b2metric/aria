# Byte-compiled
__pycache__/
*.py[cod]
*.egg-info/

# Virtualenv
.venv/
venv/
.env

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Build
dist/
build/
*.egg

# Coverage
htmlcov/
.coverage
.coverage.*
coverage.xml

# Node
node_modules/
.next/
out/

# Docker volumes (keep compose file, ignore data)
!docker-compose*.yml
!docker-compose*.yaml

# Secrets
*.pem
*.key
.env.local
.env.production

# Alembic
backend/alembic/versions/*.pyc

# Prefect
~/.prefect/
tmp/
\n# Next.js clobber folders\n.next.clobbered-by-build/\nfrontend/.next.clobbered-by-build/
\nfrontend/.next*

# LLM stack secrets (copied from hermes-llm-infra)
infra/llm/.env

# code knowledge graph (generated)
codegraph/graph.json
codegraph/graph.html
codegraph/drift-audit.json
frontend/tsconfig.tsbuildinfo
frontend/test-results/

# Hermes repo-local profile (config-as-code): default-deny — commit config, NEVER secrets/state
.hermes/*
!.hermes/config.yaml
!.hermes/SOUL.md
!.hermes/.env.example
!.hermes/README.md
!.hermes/agents/
# skills: commit ONLY engineering-core (the project discipline). The generic Hermes skill
# library + curator state/backups (.tar.gz binaries) + skill docs with example keys stay
# on disk for the runtime agent but OUT of git.
!.hermes/skills/
.hermes/skills/*
!.hermes/skills/engineering-core/
