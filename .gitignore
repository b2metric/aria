tmp/
\n# Next.js clobber folders\n.next.clobbered-by-build/\nfrontend/.next.clobbered-by-build/
\nfrontend/.next*

# LLM stack secrets (copied from hermes-llm-infra)
infra/llm/.env

# code knowledge graph (generated)
codegraph/graph.json
codegraph/graph.html
codegraph/drift-audit.json
frontend/tsconfig.tsbuildinfo
frontend/test-results/
frontend/coverage/

# Generated business PDFs (regenerable from docs/business/*.md; keep on disk, out of git)
docs/business/pdf/

# Claude Code: local-only settings + router config (never commit the real LiteLLM key)
.claude/settings.local.json

# scratch debug scripts (throwaway, not real tests)
backend/scripts/test_*.py

# Playwright MCP debug artifacts (console logs, page snapshots, screenshots)
.playwright-mcp/
