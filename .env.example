# ARIA Environment Variables (Development)
# Copy to .env and adjust as needed.

# ── Database ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aria:aria_dev@localhost:5432/aria
DATABASE_URL_SYNC=postgresql://aria:aria_dev@localhost:5432/aria

# ── Redis ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Keycloak ───────────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=aria
KEYCLOAK_CLIENT_ID=aria-backend

# ── MinIO ──────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aria

# ── Qdrant ─────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── Prefect ────────────────────────────────────────────────────────────
PREFECT_API_URL=http://localhost:4200/api

# ── Sentry ─────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ── Auth (JWT) ─────────────────────────────────────────────────────────
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60

# ── App ────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=debug
