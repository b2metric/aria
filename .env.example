# ARIA Environment Variables (Development)
# Copy to .env and adjust as needed.

# ── Database ───────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://aria:aria_dev@localhost:5432/aria
DATABASE_URL_SYNC=postgresql://aria:aria_dev@localhost:5432/aria

# ── Redis ──────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Keycloak ───────────────────────────────────────────────────────────
KEYCLOAK_URL=http://localhost:8080
KEYCLOAK_REALM=aria
KEYCLOAK_CLIENT_ID=aria-backend
KEYCLOAK_CLIENT_SECRET=

# ── Auth (JWT) ─────────────────────────────────────────────────────────
# Keycloak RS256 public key is fetched automatically from the JWKS
# endpoint.  The settings below are used as fallback for local testing.
JWT_SECRET_KEY=change-me-in-production-use-openssl-rand-hex-32
JWT_ALGORITHM=RS256
JWT_LEEWAY_SECONDS=30

# ── MinIO ──────────────────────────────────────────────────────────────
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=aria

# ── Qdrant ─────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333

# ── Prefect ────────────────────────────────────────────────────────────
PREFECT_API_URL=http://localhost:4200/api

# ── Sentry ─────────────────────────────────────────────────────────────
SENTRY_DSN=
SENTRY_ENVIRONMENT=development

# ── App ────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=debug

# ── Oracle Thick Mode ──────────────────────────────────────────────
# Path to Oracle Instant Client (required for thick mode features)
# See docs/oracle-instant-client-setup.md for installation
# ORACLE_CLIENT_LIB_DIR=/opt/oracle/instantclient_23_3
